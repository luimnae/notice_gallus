---
import { site, docOrder } from '../data/site';
interface Props {
  active: string;
}
const { active } = Astro.props;
const href = (slug: string) => `/${slug}/`;
---
<nav class="docnav" aria-label="Notices">
  {docOrder.map((slug) => {
    const d = site[slug];
    return (
      <a
        class={`docnav__btn${slug === active ? ' is-active' : ''}`}
        href={href(slug)}
        aria-current={slug === active ? 'page' : undefined}
      >
        <span class="tnum">{d.num}</span> <span class="dn-title">{d.title}</span>
      </a>
    );
  })}
</nav>

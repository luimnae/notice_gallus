---
// Hairline icon set — 24x24, stroke currentColor, thin & architectural.
interface Props {
  name: string;
  size?: number;
  sw?: number;
  class?: string;
}
const { name, size = 24, sw = 1.4, class: cls } = Astro.props;

const paths: Record<string, string> = {
  window: '<rect x="3.5" y="3.5" width="17" height="17"/><path d="M12 3.5v17M3.5 12h17"/>',
  shutter: '<rect x="3.5" y="3.5" width="17" height="17"/><path d="M3.5 8h17M3.5 12h17M3.5 16h17"/>',
  wrench:
    '<path d="M14.5 6.5a3.5 3.5 0 0 1-4.6 4.6L5 16l3 3 4.9-4.9a3.5 3.5 0 0 0 4.6-4.6l-2 2-2-.5-.5-2 2-2z"/>',
  arrowRight: '<path d="M5 12h14M13 6l6 6-6 6"/>',
  arrowLeft: '<path d="M19 12H5M11 18l-6-6 6-6"/>',
  check: '<path d="M4 12.5l5 5L20 6"/>',
  dot: '<circle cx="12" cy="12" r="2.4" fill="currentColor" stroke="none"/>',
  alert: '<path d="M12 3.2 1.6 21h20.8L12 3.2z"/><path d="M12 9.5v5M12 17.6h.01"/>',
  info: '<circle cx="12" cy="12" r="9"/><path d="M12 11v5M12 7.8h.01"/>',
  tool: '<path d="M3 7h11M3 12h7M3 17h11"/><circle cx="18" cy="7" r="2.2"/><circle cx="14" cy="12" r="2.2"/><circle cx="18" cy="17" r="2.2"/>',
  layers:
    '<path d="M12 3 2.5 8 12 13l9.5-5L12 3z"/><path d="M2.5 13.5 12 18.5l9.5-5M2.5 18 12 23l9.5-5" opacity=".55"/>',
  target: '<circle cx="12" cy="12" r="8.5"/><circle cx="12" cy="12" r="3.6"/>',
  list: '<path d="M8 6h12M8 12h12M8 18h12M4 6h.01M4 12h.01M4 18h.01"/>',
  home: '<path d="M4 11 12 4l8 7M6 9.5V20h12V9.5"/>',
};
const body = paths[name] ?? '';
---
<svg
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill="none"
  stroke="currentColor"
  stroke-width={sw}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={cls}
  aria-hidden="true"
  set:html={body}
/>

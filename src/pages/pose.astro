---
import Base from '../layouts/Base.astro';
import Notice from '../components/Notice.astro';
import { site } from '../data/site';
const doc = site.pose;
---
<Base title={doc.title} description={`${doc.title} — ${doc.subtitle}`} active="pose">
  <Notice doc={doc} />
</Base>
<script>
  import '../scripts/notice.ts';
</script>
